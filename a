local function autoPlayGetMySide()
	local plots = workspace:FindFirstChild("Plots")
	if not plots then
		return nil
	end

	for _, plot in pairs(plots:GetChildren()) do
		for _, obj in pairs(plot:GetDescendants()) do
			local text = (obj:IsA("TextLabel") or obj:IsA("TextBox")) and obj.Text or nil
			if text and (string.find(text, LocalPlayer.Name) or string.find(text, LocalPlayer.DisplayName)) then
				local ref = plot:FindFirstChild("StealHitbox")
					or plot:FindFirstChild("MainRoot")
					or plot:FindFirstChildWhichIsA("BasePart", true)
				if ref then
					return (ref.Position.Z > 60) and "Left" or "Right"
				end
			end
		end
	end
	return nil
end

local function autoPlayWalkTo(targetPos, waypointDelay)
	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not hum or not root then
		return
	end

	local function applyAutoPlaySpeed()
		-- Always follow speed customizer values (normal or steal speed).
		local spd = getActiveSpeed(char)
		hum.WalkSpeed = spd
		local toTarget = targetPos - root.Position
		local flatDir = Vector3.new(toTarget.X, 0, toTarget.Z)
		if flatDir.Magnitude > 0.01 then
			local dir = flatDir.Unit
			root.AssemblyLinearVelocity = Vector3.new(
				dir.X * spd,
				root.AssemblyLinearVelocity.Y,
				dir.Z * spd
			)
		end
	end

	applyAutoPlaySpeed()
	hum:MoveTo(targetPos)
	local startT = tick()
	while autoPlayRunning and not autoPlayStop and (root.Position - targetPos).Magnitude > 3 do
		applyAutoPlaySpeed()
		autoPlayInstantSteal()
		if tick() - startT > 3 then
			hum.Jump = true
			hum:MoveTo(targetPos)
			startT = tick()
		end
		task.wait()
	end
	local delay = math.max(waypointDelay or 0, 0)
	if delay > 0 and autoPlayRunning and not autoPlayStop then
		local t0 = tick()
		while autoPlayRunning and not autoPlayStop and (tick() - t0) < delay do
			task.wait()
		end
	end
end

local function autoPlayRunRoute()
	local mySide = autoPlayGetMySide()
	if not mySide then
		return
	end
	local targetSide = (mySide == "Left") and "Right" or "Left"
	local waypoints = AutoPlaySettings.Paths[targetSide]
	autoPlayCreateMarkers(waypoints)
	for i = 1, #waypoints do
		if autoPlayStop or not autoPlayRunning then
			break
		end
		autoPlayWalkTo(waypoints[i], AutoPlaySettings.Delay)
		if autoPlayStop or not autoPlayRunning then
			break
		end
	end
end

