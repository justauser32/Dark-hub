-- DRAGGABLE
function MakeDraggable(obj, parent, saveKey)
	local dragging, dragStart, startPos, moved
	obj.InputBegan:Connect(function(input)
		if Flags.UiLock then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			moved = false
			dragStart = input.Position
			startPos = parent.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			parent.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
			moved = true
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
			if moved and saveKey then
				uiPosState[saveKey] = {
					xs = parent.Position.X.Scale,
					xo = parent.Position.X.Offset,
					ys = parent.Position.Y.Scale,
					yo = parent.Position.Y.Offset,
				}
				saveAutoConfig()
			end
		end
	end)
end

function setupDarkHubESP()
	local ESPData = {}

	local function getOrCreateESP(plr)
		local data = ESPData[plr]
		if data then
			return data
		end

		local h = Instance.new("Highlight")
		h.Name = "DarkHub_ESP"
		h.FillTransparency = 0.7
		h.OutlineTransparency = 0
		h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		h.Enabled = false
		h.Parent = ScreenGui

		local billboard = Instance.new("BillboardGui")
		billboard.Name = "DarkHub_ESP_Billboard"
		billboard.Size = UDim2.new(0, 140, 0, 22)
		billboard.StudsOffset = Vector3.new(0, 2.6, 0)
		billboard.AlwaysOnTop = true
		billboard.Enabled = false
		billboard.MaxDistance = 500
		billboard.Parent = ScreenGui

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 1
		label.Font = Theme.Font
		label.TextSize = 11
		label.TextStrokeTransparency = 0
		label.TextStrokeColor3 = Color3.new(0, 0, 0)
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.Text = ""
		label.Parent = billboard

		data = { Highlight = h, Billboard = billboard, Label = label }
		ESPData[plr] = data
		return data
	end

	local function clearESP(plr)
		local data = ESPData[plr]
		if not data then
			return
		end
		if data.Highlight then
			data.Highlight:Destroy()
		end
		if data.Billboard then
			data.Billboard:Destroy()
		end
		ESPData[plr] = nil
	end

	Players.PlayerRemoving:Connect(clearESP)
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			getOrCreateESP(p)
		end
	end
	Players.PlayerAdded:Connect(function(p)
		if p ~= LocalPlayer then
			getOrCreateESP(p)
		end
	end)

	-- CORE LOOPS
	RunService.Stepped:Connect(function()
		if Flags.NoWalkAnim then ToggleAnims(true) end
		if Flags.NoCollision and LocalPlayer.Character then
			for _, plr in pairs(Players:GetPlayers()) do
				if plr ~= LocalPlayer and plr.Character then
					for _, part in pairs(plr.Character:GetDescendants()) do
						if part:IsA("BasePart") then
							part.CanCollide = false
						end
					end
				end
			end
		end
	end)

	UserInputService.JumpRequest:Connect(function()
		if Flags.InfiniteJump and LocalPlayer.Character then
			local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
			if hrp and hum then
				hrp.Velocity = Vector3.new(hrp.Velocity.X, hum.JumpPower, hrp.Velocity.Z)
			end
		end
	end)

	local frameHistory = {}
	RunService.RenderStepped:Connect(function(dt)
		table.insert(frameHistory, 1 / dt)
		if #frameHistory > 15 then table.remove(frameHistory, 1) end

		local s = 0
		for _, v in pairs(frameHistory) do
			s += v
		end
		FPSLabel.Text = "FPS: " .. math.floor(s / #frameHistory)
		MSLabel.Text = "PING: " .. math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms"

		local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		for plr, data in pairs(ESPData) do
			local char = plr.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local root = char and char:FindFirstChild("HumanoidRootPart")
			local head = char and char:FindFirstChild("Head")
			local alive = hum and hum.Health > 0
			local visible = Flags.ESP and char and root and alive

			data.Highlight.Enabled = visible and true or false
			data.Billboard.Enabled = visible and true or false

			if visible then
				local hpRatio = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
				local hpColor = Color3.fromRGB(255 * (1 - hpRatio), 255 * hpRatio, 80)
				data.Highlight.FillColor = hpColor
				data.Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
				data.Highlight.Adornee = char

				data.Billboard.Adornee = head or root
				local dist = myRoot and math.floor((root.Position - myRoot.Position).Magnitude) or 0
				data.Label.Text = string.format("%s | %dm | %dHP", plr.Name, dist, math.floor(hum.Health))
				data.Label.TextColor3 = hpColor
			end
		end
	end)
end

