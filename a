local function refreshAutoOffsetUi(side, idx)
	local b = autoAxisBoxes[side] and autoAxisBoxes[side][idx]
	local off = AutoPlayOffsets[side] and AutoPlayOffsets[side][idx]
	if b and off then
		b.X.Text = formatAxis(off.X)
		b.Y.Text = formatAxis(off.Y)
	end
end

local function refreshAllAutoOffsetUi()
	for _, side in ipairs({ "Left", "Right" }) do
		for i = 1, 4 do
			refreshAutoOffsetUi(side, i)
		end
	end
end

local function syncOffsetFromWorld(side, idx, worldPos)
	local base = AutoPlayBasePaths[side] and AutoPlayBasePaths[side][idx]
	if not base then
		return
	end
	AutoPlayOffsets[side][idx] = Vector2.new(worldPos.X - base.X, worldPos.Z - base.Z)
	applyAutoPlayPoint(side, idx)
	refreshAutoOffsetUi(side, idx)
end

local function nudgeWaypoint(side, idx, dx, dz)
	local current = AutoPlaySettings.Paths[side] and AutoPlaySettings.Paths[side][idx]
	if not current then
		return
	end
	dx = dx or 0
	dz = dz or 0
	local newPos = Vector3.new(current.X + (dx * autoMoveNudgeStep), current.Y, current.Z + (dz * autoMoveNudgeStep))
	AutoPlaySettings.Paths[side][idx] = newPos
	syncOffsetFromWorld(side, idx, newPos)

	for _, marker in ipairs(autoPlayMarkers) do
		if marker
			and marker.Parent
			and marker:GetAttribute("AutoSide") == side
			and marker:GetAttribute("AutoIdx") == idx then
			marker.Position = newPos
			break
		end
	end
	saveAutoConfig()
end

