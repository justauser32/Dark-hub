		if r:IsA("RemoteEvent") then
			pcall(function() r:FireServer(targetChar) end)
			pcall(function() r:FireServer(targetRoot) end)
			pcall(function() r:FireServer(targetRoot.Position) end)
			pcall(function() r:FireServer(targetChar, targetRoot.Position) end)
		else
			pcall(function() r:InvokeServer(targetChar) end)
			pcall(function() r:InvokeServer(targetRoot.Position) end)
		end
	end
end

