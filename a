local function buildAutoPlayConfigString()
	local payload = {
		v = 1,
		delay = AutoPlaySettings.Delay,
		offsets = {
			Left = {},
			Right = {},
		},
	}
	for _, side in ipairs({ "Left", "Right" }) do
		for i = 1, 4 do
			local o = AutoPlayOffsets[side][i]
			table.insert(payload.offsets[side], { x = o.X, y = o.Y })
		end
	end
	return HttpService:JSONEncode(payload)
end

local function importAutoPlayConfigString(raw)
	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(raw)
	end)
	if not ok or type(decoded) ~= "table" or type(decoded.offsets) ~= "table" then
		return false
	end
	if type(decoded.delay) == "number" and decoded.delay >= 0 then
		AutoPlaySettings.Delay = decoded.delay
		DelayBox.Text = tostring(AutoPlaySettings.Delay)
	end
	for _, side in ipairs({ "Left", "Right" }) do
		local arr = decoded.offsets[side]
		if type(arr) == "table" then
			for i = 1, 4 do
				local item = arr[i]
				if type(item) == "table" and type(item.x) == "number" and type(item.y) == "number" then
					AutoPlayOffsets[side][i] = Vector2.new(item.x, item.y)
					applyAutoPlayPoint(side, i)
				end
			end
		end
	end
	refreshAllAutoOffsetUi()
	if autoMoveToolEnabled then
		createMoveToolMarkers(autoMoveSide)
	end
	saveAutoConfig()
	return true
end

