-- ANTI-LAG SYSTEM (reduces client GPU/CPU load; does not change real network ping shown in PING:)
local AntiLagState = {
	conns = {},
	castShadowParts = {},
	effectOff = {}, -- [Instance] = previous Enabled
	postEffectOff = {},
	savedGlobalShadows = nil,
	savedLightingTechnology = nil,
	savedQuality = nil,
	savedMeshDetail = nil,
	savedRenderQuality = nil,
	terrainWaterWave = nil,
	terrainDecoration = nil,
}

local function antiLagStripVfx(inst)
	if inst:IsA("ParticleEmitter") or inst:IsA("Trail") or inst:IsA("Beam")
		or inst:IsA("Fire") or inst:IsA("Smoke") or inst:IsA("Sparkles") then
		if inst.Enabled then
			inst.Enabled = false
			AntiLagState.effectOff[inst] = true
		end
	elseif inst:IsA("BasePart") then
		if inst.CastShadow then
			inst.CastShadow = false
			table.insert(AntiLagState.castShadowParts, inst)
		end
	end
end

local function antiLagStripCharacter(char, isLocal)
	for _, item in ipairs(char:GetChildren()) do
		if item:IsA("Accessory") or item:IsA("Clothing") then
			item:Destroy()
		end
	end
	if not isLocal then
		local animScript = char:FindFirstChild("Animate")
		if animScript then
			animScript.Enabled = false
		end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			for _, track in pairs(hum:GetPlayingAnimationTracks()) do
				track:Stop()
			end
		end
	end
	for _, d in ipairs(char:GetDescendants()) do
		antiLagStripVfx(d)
		if d:IsA("PointLight") or d:IsA("SpotLight") or d:IsA("SurfaceLight") then
			if d.Enabled then
				d.Enabled = false
				AntiLagState.effectOff[d] = true
			end
		end
	end
end

local function antiLagApplyWorkspace()
	for _, v in ipairs(workspace:GetDescendants()) do
		antiLagStripVfx(v)
	end
end

function SuperAntiLag(enabled)
	Flags.AntiLag = enabled

	for _, c in ipairs(AntiLagState.conns) do
		c:Disconnect()
	end
	table.clear(AntiLagState.conns)

	if not enabled then
		Lighting.GlobalShadows = AntiLagState.savedGlobalShadows ~= nil and AntiLagState.savedGlobalShadows or true
		if AntiLagState.savedLightingTechnology ~= nil then
			pcall(function()
				Lighting.Technology = AntiLagState.savedLightingTechnology
			end)
		end
		AntiLagState.savedLightingTechnology = nil
		AntiLagState.savedGlobalShadows = nil

		for inst, wasOn in pairs(AntiLagState.postEffectOff) do
			pcall(function()
				if inst.Parent then
					inst.Enabled = wasOn
				end
			end)
		end
		table.clear(AntiLagState.postEffectOff)

		for _, p in ipairs(AntiLagState.castShadowParts) do
			pcall(function()
				p.CastShadow = true
			end)
		end
		table.clear(AntiLagState.castShadowParts)

		for inst, _ in pairs(AntiLagState.effectOff) do
			pcall(function()
				if inst.Parent then
					inst.Enabled = true
				end
			end)
		end
		table.clear(AntiLagState.effectOff)

		pcall(function()
			local ug = UserSettings():GetService("UserGameSettings")
			if AntiLagState.savedQuality ~= nil then
				ug.SavedQualityLevel = AntiLagState.savedQuality
			end
		end)
		AntiLagState.savedQuality = nil

		pcall(function()
			local r = settings().Rendering
			if AntiLagState.savedRenderQuality ~= nil then
				r.QualityLevel = AntiLagState.savedRenderQuality
			end
			if AntiLagState.savedMeshDetail ~= nil then
				r.MeshPartDetailLevel = AntiLagState.savedMeshDetail
			end
		end)
		AntiLagState.savedRenderQuality = nil
		AntiLagState.savedMeshDetail = nil

		pcall(function()
			local t = workspace.Terrain
			if AntiLagState.terrainWaterWave ~= nil then
				t.WaterWaveSize = AntiLagState.terrainWaterWave
			end
			if AntiLagState.terrainDecoration ~= nil then
				t.Decoration = AntiLagState.terrainDecoration
			end
		end)
		AntiLagState.terrainWaterWave = nil
		AntiLagState.terrainDecoration = nil

		return
	end

	-- enable: snapshot & apply aggressive settings
	AntiLagState.savedGlobalShadows = Lighting.GlobalShadows
	Lighting.GlobalShadows = false

	pcall(function()
		AntiLagState.savedLightingTechnology = Lighting.Technology
		Lighting.Technology = Enum.Technology.Compatibility
	end)

	for _, child in ipairs(Lighting:GetChildren()) do
		if child:IsA("PostEffect") and child.Enabled then
			AntiLagState.postEffectOff[child] = child.Enabled
			child.Enabled = false
		end
	end

	pcall(function()
		local ug = UserSettings():GetService("UserGameSettings")
		AntiLagState.savedQuality = ug.SavedQualityLevel
		ug.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
	end)

	pcall(function()
		local r = settings().Rendering
		AntiLagState.savedRenderQuality = r.QualityLevel
		AntiLagState.savedMeshDetail = r.MeshPartDetailLevel
		r.QualityLevel = Enum.QualityLevel.Level01
		r.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01
	end)

	pcall(function()
		local t = workspace.Terrain
		AntiLagState.terrainWaterWave = t.WaterWaveSize
		AntiLagState.terrainDecoration = t.Decoration
		t.WaterWaveSize = 0
		t.Decoration = false
	end)

	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character then
			antiLagStripCharacter(p.Character, p == LocalPlayer)
		end
	end

	antiLagApplyWorkspace()

	table.insert(
		AntiLagState.conns,
		workspace.DescendantAdded:Connect(function(inst)
			if not Flags.AntiLag then
				return
			end
			antiLagStripVfx(inst)
			if inst:IsA("PointLight") or inst:IsA("SpotLight") or inst:IsA("SurfaceLight") then
				if inst.Enabled then
					inst.Enabled = false
					AntiLagState.effectOff[inst] = true
				end
			end
		end)
	)

	local function connectCharStrip(p)
		return p.CharacterAdded:Connect(function(char)
			if not Flags.AntiLag then
				return
			end
			task.defer(function()
				if Flags.AntiLag and char.Parent then
					antiLagStripCharacter(char, p == LocalPlayer)
				end
			end)
		end)
	end

	for _, p in ipairs(Players:GetPlayers()) do
		table.insert(AntiLagState.conns, connectCharStrip(p))
	end
	table.insert(
		AntiLagState.conns,
		Players.PlayerAdded:Connect(function(p)
			table.insert(AntiLagState.conns, connectCharStrip(p))
			if Flags.AntiLag and p.Character then
				task.defer(function()
					if Flags.AntiLag and p.Character then
						antiLagStripCharacter(p.Character, p == LocalPlayer)
					end
				end)
			end
		end)
	)
end

