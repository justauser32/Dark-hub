-- Main Speed Loop (Velocity-Based Heartbeat)
RunService.Heartbeat:Connect(function()
	if SpeedSettings.Enabled then
		local character = LocalPlayer.Character
		if not character then return end

		local humanoid = character:FindFirstChildOfClass("Humanoid")
		local root = character:FindFirstChild("HumanoidRootPart")

		if root and humanoid and humanoid.MoveDirection.Magnitude > 0 then
			local moveDir = humanoid.MoveDirection
			local spd = getActiveSpeed(character)

			root.AssemblyLinearVelocity = Vector3.new(
				moveDir.X * spd,
				root.AssemblyLinearVelocity.Y,
				moveDir.Z * spd
			)
		end
	end
end)

-- Lock follow (runs after speed Heartbeat so it wins when both apply)
RunService.Heartbeat:Connect(function()
	local character = LocalPlayer.Character
	local currentHRP = character and character:FindFirstChild("HumanoidRootPart")
	if not currentHRP or not lockAlign then return end

	local hum = character:FindFirstChildOfClass("Humanoid")
	if not (Flags.Lock and isFollowing) then
		lockAlign.Enabled = false
		if hum then hum.AutoRotate = true end
		return
	end

	lockAlign.Enabled = true
	if hum then hum.AutoRotate = false end

	local targetHRP, targetChar = getLockTarget(currentHRP)

	if targetHRP then
		local targetVelocity = targetHRP.AssemblyLinearVelocity
		local speed = targetVelocity.Magnitude

		local predictTime = math.clamp(speed / 150, 0.05, 0.2)

		local predictedPos = targetHRP.Position + (targetVelocity * predictTime)

		local toPredicted = predictedPos - currentHRP.Position
		local distance = toPredicted.Magnitude

		local standPos = predictedPos
		if distance > 0 then
			standPos = predictedPos - (toPredicted.Unit * MELEE_OFFSET)
		end

		lockAlign.CFrame = CFrame.lookAt(currentHRP.Position, predictedPos)

		local moveDir = (standPos - currentHRP.Position)
		local moveMag = moveDir.Magnitude

		if moveMag > 1 then
			local spd = getActiveSpeed(character)
			currentHRP.AssemblyLinearVelocity =
				(moveDir.Unit * spd) + (targetVelocity * 0.35)
		else
			currentHRP.AssemblyLinearVelocity = targetVelocity
		end
	else
		lockedTarget = nil
		currentHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	end
end)

