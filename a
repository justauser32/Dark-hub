		end
		if input.KeyCode == Enum.KeyCode.Escape then
			listeningDropKey = false
			DropKeybindBtn.Text = dropKeybindCode and dropKeybindCode.Name or "NONE"
			DropKeybindBtn.TextColor3 = Theme.TextDark
