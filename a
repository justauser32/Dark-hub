local function bindNudgeHold(button, dx, dz)
	local holding = false
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			holding = true
			if not autoMoveToolEnabled then
				enableMoveTool()
			end
			nudgeWaypoint(autoMoveSide, autoMoveSelectedIdx, dx, dz)
			task.spawn(function()
				task.wait(0.2)
				while holding do
					nudgeWaypoint(autoMoveSide, autoMoveSelectedIdx, dx, dz)
					task.wait(0.08)
				end
			end)
		end
	end)
	button.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			holding = false
		end
	end)
end

