local function serializeConfig()
	local data = {
		flags = {},
		speed = { enabled = SpeedSettings.Enabled, speed = SpeedSettings.Speed, steal = SpeedSettings.Steal },
		floatHeight = (FloatSettings and FloatSettings.Height) or loadedFloatHeight,
		autoPlayDelay = AutoPlaySettings.Delay,
		autoPlayOffsets = { Left = {}, Right = {} },
		uiPos = uiPosState,
		keybinds = {
			lock = lockKeybindCode and lockKeybindCode.Name or nil,
			float = floatKeybindCode and floatKeybindCode.Name or nil,
			drop = dropKeybindCode and dropKeybindCode.Name or nil,
			autoPlay = autoPlayKeybindCode and autoPlayKeybindCode.Name or nil,
		},
	}
	for k, _ in pairs(DEFAULT_FLAGS) do
		data.flags[k] = Flags[k] and true or false
	end
	for _, side in ipairs({ "Left", "Right" }) do
		for i = 1, 4 do
			local o = AutoPlayOffsets[side][i]
			table.insert(data.autoPlayOffsets[side], { x = o.X, y = o.Y })
		end
	end
	return data
end

local function saveAutoConfig()
	if suppressAutoSave or not writefile then
		return
	end
	local ok, encoded = pcall(function()
		return HttpService:JSONEncode(serializeConfig())
	end)
	if ok then
		pcall(function()
			writefile(CONFIG_FILE, encoded)
		end)
	end
end

local function loadAutoConfig()
	if not (isfile and readfile) then
		return
	end
	local ok, raw = pcall(function()
		if isfile(CONFIG_FILE) then
			return readfile(CONFIG_FILE)
		end
	end)
	if not ok or not raw or raw == "" then
		return
	end
	local okDecode, data = pcall(function()
		return HttpService:JSONDecode(raw)
	end)
	if not okDecode or type(data) ~= "table" then
		return
	end

	if type(data.flags) == "table" then
		for k, _ in pairs(DEFAULT_FLAGS) do
			if type(data.flags[k]) == "boolean" then
				Flags[k] = data.flags[k]
			end
		end
	end
	if type(data.speed) == "table" then
		if type(data.speed.enabled) == "boolean" then SpeedSettings.Enabled = data.speed.enabled end
		if type(data.speed.speed) == "number" then SpeedSettings.Speed = data.speed.speed end
		if type(data.speed.steal) == "number" then SpeedSettings.Steal = data.speed.steal end
	end
	if type(data.floatHeight) == "number" then
		loadedFloatHeight = data.floatHeight
	end
	if type(data.autoPlayDelay) == "number" and data.autoPlayDelay >= 0 then
		AutoPlaySettings.Delay = data.autoPlayDelay
	end
	if type(data.autoPlayOffsets) == "table" then
		for _, side in ipairs({ "Left", "Right" }) do
			local arr = data.autoPlayOffsets[side]
			if type(arr) == "table" then
				for i = 1, 4 do
					local item = arr[i]
					if type(item) == "table" and type(item.x) == "number" and type(item.y) == "number" then
						AutoPlayOffsets[side][i] = Vector2.new(item.x, item.y)
					end
				end
			end
		end
	end
	if type(data.uiPos) == "table" then
		for key, _ in pairs(DEFAULT_UI_POSITIONS) do
			local parsed = posToUDim2(data.uiPos[key])
			if parsed then
				uiPosState[key] = data.uiPos[key]
			end
		end
	end
	if type(data.keybinds) == "table" then
		if type(data.keybinds.lock) == "string" and Enum.KeyCode[data.keybinds.lock] then lockKeybindCode = Enum.KeyCode[data.keybinds.lock] end
		if type(data.keybinds.float) == "string" and Enum.KeyCode[data.keybinds.float] then floatKeybindCode = Enum.KeyCode[data.keybinds.float] end
		if type(data.keybinds.drop) == "string" and Enum.KeyCode[data.keybinds.drop] then dropKeybindCode = Enum.KeyCode[data.keybinds.drop] end
		if type(data.keybinds.autoPlay) == "string" and Enum.KeyCode[data.keybinds.autoPlay] then autoPlayKeybindCode = Enum.KeyCode[data.keybinds.autoPlay] end
	end
end

