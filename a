-- ========== FLOAT (hover) + Float HUD ==========
local FloatSettings = { Height = 10 }
FloatSettings.Height = loadedFloatHeight
local floatRayAboveFeet = 3
local floatRayLengthDown = 120
local floatKp = 380
local floatKd = 95
local floatMaxLiftMult = 2.6
local floatForceSmoothingTau = 14

local floatSimConn, floatInputConn, floatInst
local isFloatOn = false

local function destroyFloatPhysics()
	if floatInst then
		local f = floatInst
		floatInst = nil
		pcall(function()
			if f.vf then
				f.vf:Destroy()
			end
		end)
		pcall(function()
			if f.att then
				f.att:Destroy()
			end
		end)
	end
end

local function disconnectFloatSession()
	if floatSimConn then
		floatSimConn:Disconnect()
		floatSimConn = nil
	end
	if floatInputConn then
		floatInputConn:Disconnect()
		floatInputConn = nil
	end
	destroyFloatPhysics()
end

local function floatFootY(hrp, humanoid)
	return hrp.Position.Y - hrp.Size.Y * 0.5 - humanoid.HipHeight
end

local function floatRaycastGround(hrp, humanoid, character)
	local pos = hrp.Position
	local footY = floatFootY(hrp, humanoid)
	local startY = footY + floatRayAboveFeet
	local direction = Vector3.new(0, -floatRayLengthDown, 0)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { character }
	local offsets = {
		Vector3.new(0, 0, 0),
		Vector3.new(1.75, 0, 0),
		Vector3.new(-1.75, 0, 0),
		Vector3.new(0, 0, 1.75),
		Vector3.new(0, 0, -1.75),
	}
	local bestY = nil
	for _, off in ipairs(offsets) do
		local origin = Vector3.new(pos.X + off.X, startY, pos.Z + off.Z)
		local result = workspace:Raycast(origin, direction, params)
		if result then
			local gy = result.Position.Y
			if not bestY or gy > bestY then
				bestY = gy
			end
		end
	end
	return bestY
end

local function floatHrpTargetY(groundY, humanoid, hrp)
	return groundY + FloatSettings.Height + humanoid.HipHeight + hrp.Size.Y * 0.5
end

local function snapFloatToGround(hrp, humanoid, character)
	local groundY = floatRaycastGround(hrp, humanoid, character)
	if not groundY then
		return
	end
	local y = groundY + humanoid.HipHeight + hrp.Size.Y * 0.5
	local pos = hrp.Position
	local flat = Vector3.new(pos.X, y, pos.Z)
	hrp.CFrame = CFrame.new(flat) * (hrp.CFrame - hrp.CFrame.Position)
	hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
end

local function createFloatPhysics(hrp)
	destroyFloatPhysics()
	local att = Instance.new("Attachment")
	att.Name = "FloatAbove_Att"
	att.Parent = hrp
	local vf = Instance.new("VectorForce")
	vf.Name = "FloatAbove_VF"
	vf.Attachment0 = att
	vf.RelativeTo = Enum.ActuatorRelativeTo.World
	vf.ApplyAtCenterOfMass = true
	vf.Force = Vector3.zero
	vf.Parent = hrp
	floatInst = { att = att, vf = vf }
	return vf
end

local function connectFloatSimulation(callback)
	local ps = RunService.PostSimulation
	if ps then
		return ps:Connect(callback)
	end
	return RunService.Heartbeat:Connect(callback)
end

local FloatHUD, FloatHUDGradient, FloatPulse

local function resetFloatHUDVisual()
	isFloatOn = false
	if FloatHUD then
		FloatHUD.Text = "FLOAT"
		FloatHUD.TextColor3 = Theme.TextMain
	end
	if FloatHUDGradient then
		FloatHUDGradient.Color = Theme.SilverGradient
	end
	if FloatPulse then
		FloatPulse.BackgroundTransparency = 1
	end
end

local function attachFloatCharacter(character)
	disconnectFloatSession()

	local humanoid = character:WaitForChild("Humanoid")
	local hrp = character:WaitForChild("HumanoidRootPart")

	local floating = true
	local lockedTargetY = nil
	local smoothedForceY = nil

	createFloatPhysics(hrp)

	floatInputConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then
			return
		end
		if input.KeyCode ~= Enum.KeyCode.Q then
			return
		end
		floating = false
		destroyFloatPhysics()
		snapFloatToGround(hrp, humanoid, character)
		resetFloatHUDVisual()
	end)

	floatSimConn = connectFloatSimulation(function(dt)
		if not floating or humanoid.Health <= 0 then
			return
		end
		local vf = floatInst and floatInst.vf
		if not vf or not vf.Parent then
			return
		end

		if typeof(dt) ~= "number" or dt <= 0 or dt > 0.5 then
			dt = 1 / 60
		end

		if not lockedTargetY then
			local gy = floatRaycastGround(hrp, humanoid, character)
			if gy then
				lockedTargetY = floatHrpTargetY(gy, humanoid, hrp)
			else
				lockedTargetY = hrp.Position.Y + FloatSettings.Height
			end
		end

		local mass = hrp.AssemblyMass
		if not mass or mass <= 0 then
			mass = hrp:GetMass()
		end
		local g = workspace.Gravity
		local weight = mass * g

		local err = lockedTargetY - hrp.Position.Y
		local vy = hrp.AssemblyLinearVelocity.Y
		local targetForceY = weight + floatKp * err - floatKd * vy
		targetForceY = math.clamp(targetForceY, 0, weight * floatMaxLiftMult)

		if smoothedForceY == nil then
			smoothedForceY = weight
		end
		local alpha = 1 - math.exp(-dt * floatForceSmoothingTau)
		smoothedForceY = smoothedForceY + (targetForceY - smoothedForceY) * alpha
		vf.Force = Vector3.new(0, smoothedForceY, 0)
	end)

	character.Destroying:Connect(function()
		if floatSimConn then
			floatSimConn:Disconnect()
			floatSimConn = nil
		end
		if floatInputConn then
			floatInputConn:Disconnect()
			floatInputConn = nil
		end
		destroyFloatPhysics()
	end)
end

local function startFloatSession()
	local char = LocalPlayer.Character
	if char then
		attachFloatCharacter(char)
	end
end

local function stopFloatSession()
	local wasActive = isFloatOn or floatInst ~= nil or floatSimConn ~= nil
	disconnectFloatSession()
	if wasActive then
		local char = LocalPlayer.Character
		if char then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hrp and hum then
				snapFloatToGround(hrp, hum, char)
			end
		end
	end
	resetFloatHUDVisual()
end

