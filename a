-- DROP LOGIC
local function ExecuteDrop()
	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	RunDropEffect()

	local HEIGHT = 13.5
	local UP_FORCE = 2220
	local DOWN_FORCE = -6400
	local WAIT_TIME = 0.04
	local startY = root.Position.Y

	local att = Instance.new("Attachment", root)
	local force = Instance.new("VectorForce", root)
	force.Attachment0 = att
	force.RelativeTo = Enum.ActuatorRelativeTo.World
	force.ApplyAtCenterOfMass = true
	force.Force = Vector3.new(0, UP_FORCE, 0)

	task.spawn(function()
		repeat RunService.Heartbeat:Wait() until not root or root.Position.Y >= startY + HEIGHT
		if force then force.Force = Vector3.new(0, 0, 0) end
		task.wait(WAIT_TIME)
		if force then force.Force = Vector3.new(0, DOWN_FORCE, 0) end
		repeat RunService.Heartbeat:Wait() until not root or root.Position.Y <= startY + 1
		if force then force:Destroy() end
		if att then att:Destroy() end
		if root then root.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
	end)
end

