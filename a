	autoPlayClearMarkers()
	local sides = sideFilter and { sideFilter } or { "Left", "Right" }
	for _, side in ipairs(sides) do
		local color = (side == "Left") and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(100, 255, 100)
		for i, pos in ipairs(AutoPlaySettings.Paths[side]) do
			local part = Instance.new("Part")
			part.Name = "DarkHub_AutoPoint_Edit"
			part.Size = Vector3.new(1.9, 1.9, 1.9)
			part.Shape = Enum.PartType.Ball
