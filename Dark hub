local function getMyPlotInfo()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil, nil end
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil, nil end
    local id = player:GetAttribute("PlotId") or player:GetAttribute("PlotID")
    local myPlot = plots:FindFirstChild(tostring(id))
    if not myPlot then
        local closest = nil
        local dist = 100
        for _, p in pairs(plots:GetChildren()) do
            local ref = p:FindFirstChild("StealHitbox") or p:FindFirstChild("MainRoot")
            if ref and (root.Position - ref.Position).Magnitude < dist then
                dist = (root.Position - ref.Position).Magnitude
                myPlot = p
            end
        end
    end
    if not myPlot then return nil, nil end
    local refPart = myPlot:FindFirstChild("StealHitbox") or myPlot:FindFirstChild("MainRoot")
    local mySide = "Left"
    if refPart and refPart.Position.Z < 60 then 
        mySide = "Right" 
    end
    return myPlot.Name, mySide
end

local function walkTo(targetPos)
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    hum:MoveTo(targetPos)
    local startTime = tick()
    repeat 
        task.wait(0.1)
        if tick() - startTime > 5 then
            hum.Jump = true
            hum:MoveTo(targetPos)
            startTime = tick()
        end
    until (root.Position - targetPos).Magnitude < 4
end

local function runAutoplay()
    local plotId, mySide = getMyPlotInfo()
    if plotId and mySide then
        local targetSide = (mySide == "Left") and "Right" or "Left"
        local waypoints = PATHS[targetSide]
        for i = 1, #waypoints do
            walkTo(waypoints[i])
            task.wait(0.1)
        end
    end
end

task.spawn(runAutoplay)
